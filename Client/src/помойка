                                onBlur={() => { document.querySelectorAll(`.buyersH-tr-${index}`)[indexBuyerH].childNodes[8].contentEditable = false; }}>
                                {NumberFormat(buyerH.summa)}
                              </td>
                              <td style={{ display: display, backgroundColor: bgColorH }} spellCheck='false'
                                onInput={() => {
                                  buyerH.akt = document.querySelectorAll(`.buyersH-tr-${index}`)[indexBuyerH].childNodes[9].innerText;
                                }}
                                onDoubleClick={() => {
                                  document.querySelectorAll(`.buyersH-tr-${index}`)[indexBuyerH].childNodes[9].contentEditable = true;
                                  document.querySelectorAll(`.buyersH-tr-${index}`)[indexBuyerH].childNodes[9].focus();
                                }}
                                onBlur={() => { document.querySelectorAll(`.buyersH-tr-${index}`)[indexBuyerH].childNodes[9].contentEditable = false; }}>
                                {buyerH.akt}
                              </td>
                            </>
                          }

                        </tr>


                      )
                    }
                    )}










                </>
              )
            })}
          </tbody>
        </Table>
      </div>
      <FinBlockEdit
        setOrder={setOrder}
        order={order}
        handleCloseFinBlock={handleCloseFinBlock}
        showFinBlock={showFinBlock}
        current={currentFinBlock}
        suppliersOrBuyers={suppliersOrBuyers}
      />
      <NewSupplier
        order={order}
        setOrder={setOrder}
        handleCloseNewSupplier={handleCloseNewSupplier}
        showNewSupplier={showNewSupplier}
        currentSupplier={currentSupplier}

      />
      <NewBuyer
        order={order}
        setOrder={setOrder}
        handleCloseNewBuyer={handleCloseNewBuyer}
        showNewBuyer={showNewBuyer}
        litersForSale={litersForSale}
        currentBuyer={currentBuyer}
        buyerHIndex={buyerHIndex}
      />
      <Modal centered show={show} onHide={handleCloseModal} animation={true} >
        <Modal.Header closeButton>
          <Modal.Title>Подтверждение удаления</Modal.Title>
        </Modal.Header>
        <Modal.Body>Точно удаляем?</Modal.Body>
        <Modal.Footer>

          <Button variant="secondary" onClick={handleCloseModal}>
            Еще подумаю
          </Button>
          <Button variant="primary" className='col-3' onClick={() => {

            if (deleteElement) {
              if (deleteElement.element !== 'buyerH') {
                setOrder((order) => {
                  order[deleteElement.element] = order[deleteElement.element].filter((item, ind) => ind != [deleteElement.index])
                  return (order);
                })
              }
              if (deleteElement.element === 'buyerH') {
                setOrder((order) => {
                  order.buyers[deleteElement.index].buyersH = order.buyers[deleteElement.index].buyersH.filter((item, ind) => ind != [deleteElement.indexBuyerH])
                  return (order);
                })
              }
              setDeleteElement(null);
              reload(!state);
              handleRefreshLitersForSale();
            }
            handleCloseModal();
          }}>
            Да
          </Button>

        </Modal.Footer>
      </Modal>

    </>
  );
}


export default OrderTable;